// ==========================================
// GENERIC PAGE CONTENT
// Used for CMS pages that store section JSON by page + section.
// Baru Sahib Association sections: hero, video, humanity
// ==========================================

model PageContent {
  id        String   @id @default(cuid())
  page      String
  section   String
  title     String?
  content   Json
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([page, section])
  @@index([page, sortOrder])
}

